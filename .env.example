# ==========================================
# ISV Delivery — Variaveis de Ambiente
# ==========================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.

# --- App ---
APP_ENV=local                              # local | staging | production
APP_URL=http://localhost:8000
SECRET_KEY=gerar-com-openssl-rand-hex-32

# --- Banco de dados ---
DATABASE_URL=postgresql://isv:isvpass@localhost:5432/isv_delivery

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Pagar.me ---
PAGARME_API_KEY=
PAGARME_ENCRYPTION_KEY=
PAGARME_WEBHOOK_SECRET=

# --- Google Maps APIs ---
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# --- Firebase ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- APNs (iOS push) ---
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=

# --- SMS / OTP ---
SMS_PROVIDER=zenvia                        # zenvia | twilio | totalvoice
SMS_API_KEY=
SMS_FROM=

# --- S3 ---
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Sentry (erros) ---
SENTRY_DSN=
