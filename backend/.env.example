# ==========================================
# ISV Delivery - Backend (.env.example)
# ==========================================
# Copie este arquivo para backend/.env e preencha com os valores locais.
# NUNCA commite o .env com valores reais.

# --- App ---
APP_ENV=local
APP_URL=http://localhost:8000

# Gere com: openssl rand -hex 32
SECRET_KEY=replace-with-openssl-rand-hex-32

# --- Banco de dados (Postgres via docker-compose) ---
# Porta 5433 em dev local (ver ADR-002 no vault). Internamente o container escuta 5432.
DATABASE_URL=postgresql+psycopg://isv:isvpass@localhost:5433/isv_delivery

# --- Redis (via docker-compose) ---
# Porta 6380 em dev local (ver ADR-002 no vault). Internamente o container escuta 6379.
REDIS_URL=redis://localhost:6380/0
