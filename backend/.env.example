# ==========================================
# ISV Delivery - Backend (.env.example)
# ==========================================
# Copie este arquivo para backend/.env e preencha com os valores locais.
# NUNCA commite o .env com valores reais.

# --- App ---
APP_ENV=local
APP_URL=http://localhost:8000

# Gere com: openssl rand -hex 32
SECRET_KEY=replace-with-openssl-rand-hex-32

# --- Banco de dados (Postgres via docker-compose) ---
# Porta 5433 em dev local (ver ADR-002 no vault). Internamente o container escuta 5432.
DATABASE_URL=postgresql+psycopg://isv:isvpass@localhost:5433/isv_delivery

# --- Redis (via docker-compose) ---
# Porta 6380 em dev local (ver ADR-002 no vault). Internamente o container escuta 6379.
REDIS_URL=redis://localhost:6380/0

# --- SMS Provider (ADR-025) ---
# Options: mock (dev only), zenvia (prod — pending CNPJ)
SMS_PROVIDER=mock

# --- JWT (ADR-025) ---
# Gerar com: python -c "import secrets; print(secrets.token_urlsafe(64))"
# OU script seguro sem stdout (ver CP3a do vault)
# Producao: valor diferente do dev, rotacao via deploy tool
JWT_SECRET_KEY=replace-with-python-secrets-token-urlsafe-64
JWT_EXPIRATION_MINUTES=60

# --- Rate Limit (ADR-025) ---
# Storage: REDIS_URL acima. Fail-open se Redis indisponivel.
# CP3c aplica somente os limites por IP. Limites por phone declarados aqui ficam
# disponiveis pra ativar quando phone-based extraction for implementada (debito MEDIUM).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUEST_OTP_PHONE=3/hour
RATE_LIMIT_REQUEST_OTP_IP=10/hour
RATE_LIMIT_VERIFY_OTP_PHONE=10/hour
RATE_LIMIT_VERIFY_OTP_IP=30/hour
